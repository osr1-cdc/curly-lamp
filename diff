+#           HHS.hhs_region,
+#           rwt.region_week_total
+#  -- order by a.week_ending, HHS.hhs_region, a.lineage
+#  ) AS t
+#  WHERE t.share >= 0.01
+#  ORDER BY t.lineage"
+#     ))
