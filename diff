+                                          N_new = count)],
+                   y = previous_counts_by_week[, .(LAB2  = LAB2,
+                                                   yr_wk = yr_wk,
+                                                   N_old = count)],
+                   by = c('LAB2', 'yr_wk'),
+                   all = T)
