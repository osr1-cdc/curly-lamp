+last_saturday <- function(date) {
+  # Ensure date is in Date format
+  date <- as.Date(date)
+  
+  # Get the last day of the month for each date
+  last_day <- as.Date(format(date, "%Y-%m-01")) + (31 - as.numeric(format(as.Date(format(date, "%Y-%m-01")) + 31, "%d")))
+  
+  # Find the last Saturday for each last day
+  last_sat <- last_day - (as.numeric(format(last_day, "%u")) + 1) %% 7
+  
+  return(as.Date(last_sat))
+}
