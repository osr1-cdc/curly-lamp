+          # degrees of freedom flag.
+          all.wkly2$nchs_flag_wodf = ifelse(all.wkly2$flag_eff.size == 1 |
+                                              all.wkly2$denom_count == 1 |
+                                              all.wkly2$flag_abs.ciw == 1 |
+                                              all.wkly2$flag_rel.ciw == 1,
