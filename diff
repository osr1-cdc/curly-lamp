+            
+            # calculate the time period between 2 estimates
+            all.wkly2[
+              ,
+              time_diff_days := as.numeric(as.Date(WEEK_END)) -
+                as.numeric(as.Date(data.table::shift(WEEK_END, 1, type = "lag"))),
+              by = c("USA_or_HHSRegion", "Variant")
+            ]
