+### survey design --------------------------------------------------------------
+# (used in "Not Run3" and "Run3" below. The trimmed weights that are calculated
+#  from svyDES are (optionally) used in Run2.)
+if(svy.type=="svyREG"){
+  svyDES = survey::svydesign(ids     = ~STUSAB+SOURCE,
